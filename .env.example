# Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ── OctoPrint Connection ───────────────────────────────────────────────────
# Optional — can also be passed via CLI flags to octoprint_api.py
OCTOPRINT_IP=192.168.1.100
OCTOPRINT_PORT=5000
OCTOPRINT_API_KEY=

# ── Moonraker / Mainsail Connection ───────────────────────────────────────
# Moonraker is the API server behind Mainsail/Fluidd/KlipperScreen
MOONRAKER_HOST=192.168.1.100
MOONRAKER_PORT=7125
# MOONRAKER_API_KEY=            # only if [authorization] auth is enabled
# MAINSAIL_PORT=80              # nginx port serving the Mainsail frontend

# ── Printer Pi SSH (pi_system_diagnostics, display_diagnostics, ssh_manager)
PRINTER_SSH_HOST=192.168.1.100
PRINTER_SSH_USER=pi
# PRINTER_SSH_KEY=~/.ssh/id_rsa   # preferred over password
# PRINTER_SSH_PASSWORD=

# ── Knowledge Graph (klipper-knowledge-graph skill) ───────────────────────
# GITHUB_TOKEN=                 # raises GitHub API rate limits for the scraper
# KLIPPER_SRC_DIR=              # override local Klipper clone dir (default .tmp/klipper-src)
# GRAPHIFY_OUT_DIR=             # override graph output dir (default graphify-out)
# NOTE: Graphify itself must be installed to use the knowledge graph:
#   uv tool install graphifyy && graphify install

# ── Klipper Log Path ──────────────────────────────────────────────────────
# Optional — auto-detected from common paths if not set
# KLIPPER_LOG_PATH=/home/pi/printer_data/logs/klippy.log

# ── ControlCenter Codebase Path ───────────────────────────────────────────
# Path to the ControlCenter repo for code reference searches
# Default: C:\Users\VijayRaghavVarada\Documents\Github\ControlCenter
CONTROLCENTER_PATH=C:\Users\VijayRaghavVarada\Documents\Github\ControlCenter

# ── Memory System (optional) ──────────────────────────────────────────────
# DAILY_COST_BUDGET_USD=10.0
# MAX_TOKENS_PER_TASK=100000
# EMBEDDING_MODEL=all-MiniLM-L6-v2
