# Environment variables and secrets
.env
.env.local
.env.*.local

# Google OAuth credentials
credentials.json
token.json

# Temporary files
.tmp/*
!.tmp/scripts/
!.tmp/scripts/**
.tmp/search_cache/*.json
.tmp/web_cache/*
!.tmp/search_cache/README.md
!.tmp/web_cache/README.md

# Memory database (regenerated, contains local state)
memory/*.db
memory/*.db-wal
memory/*.db-shm

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Knowledge graph artifacts (regenerated — see klipper-knowledge-graph skill)
graphify-out/
agent-data/knowledge-base/*
!agent-data/knowledge-base/README.md
.tmp/klipper-src/

# Don't ignore .vscode - we want the settings
!.vscode/
